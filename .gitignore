# Build directories
build/
build-*/
cmake-build-*/

# Compiled objects
*.o
*.obj
*.lo
*.slo
*.a
*.lib
*.so
*.so.*
*.dylib
*.exe
*.out

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
logs/

# Data files (sample data excluded)
data/*.json
!data/sample_docs.json
data/*.db
data/*.db-shm
data/*.db-wal
data/*.db-journal
data/*.txt
data/user_profiles/

# Models (keep directory structure, ignore large files)
models/*.txt
models/*.bin
models/versions/

# Index files
index/*.idx
index/*.faiss
index/*.db

# Symlinks created by CMake (build -> source)
config/config
models/models
data/data

# Config local overrides
config/local.yaml

# Dependencies (third_party should be managed separately)
third_party/cpp-httplib/
third_party/spdlog/
third_party/cppjieba/
third_party/json/
